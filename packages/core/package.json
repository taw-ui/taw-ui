{
  "name": "@taw-ui/core",
  "version": "0.0.1",
  "private": false,
  "description": "Core schemas, utilities, and motion system for taw-ui",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./motion": {
      "import": "./dist/motion.mjs",
      "require": "./dist/motion.js",
      "types": "./dist/motion.d.ts"
    },
    "./schemas/*": {
      "import": "./dist/schemas/*.mjs",
      "require": "./dist/schemas/*.js",
      "types": "./dist/schemas/*.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "peerDependencies": {
    "framer-motion": "^12.0.0"
  },
  "peerDependenciesMeta": {
    "framer-motion": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsup": "^8.3.0"
  }
}
